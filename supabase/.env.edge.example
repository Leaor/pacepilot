# Supabase Edge Function secrets template.
# Copy to `supabase/.env.edge.local` for local function serving,
# or set these with `supabase secrets set` in hosted Supabase environments.
SUPABASE_URL=
SUPABASE_ANON_KEY=
APP_ENV=development
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_FALLBACK_MODEL=
TOKEN_ENCRYPTION_KEY=
OAUTH_STATE_SECRET=
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=
STRAVA_OAUTH_SCOPE=read,activity:read,activity:write
STRAVA_WEBHOOK_VERIFY_TOKEN=
STRAVA_WEBHOOK_SUBSCRIPTION_ID=
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
GARMIN_REDIRECT_URI=
GARMIN_WEBHOOK_SECRET=
WEATHER_API_KEY=
CORS_ALLOWED_ORIGINS=
