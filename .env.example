# Expo/public client configuration only.
# Values in this file may be read by Expo web/native client builds.
# Never put service-role keys, OpenAI keys, OAuth client secrets, or webhook secrets here.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_MOCK_SUBSCRIPTIONS=true
